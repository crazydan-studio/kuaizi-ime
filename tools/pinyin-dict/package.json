{
  "name": "pinyin-dict",
  "version": "0.1.0",
  "description": "Pinyin dictionary maker",
  "author": "flytreeleft@crazydan.org",
  "license": "Apache-2.0",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "app:shell": "node src/app/shell.mjs",
    "app:shell:debug": "node --inspect-brk src/app/shell.mjs",
    "data:zi": "node src/data/zi/index.mjs",
    "data:zi:debug": "node --inspect-brk src/data/zi/index.mjs",
    "data:emoji": "node src/data/emoji/index.mjs",
    "data:phrase": "node src/data/phrase/index.mjs",
    "data:phrase:debug": "node --inspect-brk src/data/phrase/index.mjs",
    "data:phrase:cngwzj": "node src/data/phrase/cngwzj.mjs",
    "db:raw:zi": "node src/db/raw/zi/index.mjs",
    "db:raw:zi:debug": "node --inspect-brk src/db/raw/zi/index.mjs",
    "db:raw:zi:analyze": "node src/db/raw/zi/analyze/index.mjs",
    "db:raw:zi:diff": "node src/db/raw/zi/diff/index.mjs",
    "site:hanzi.crazydan.io:fetch-media": "node src/site/hanzi.crazydan.io/fetch-media.mjs",
    "site:hanzi.crazydan.io:gen-stroke": "bash src/site/hanzi.crazydan.io/gen-stroke.sh",
    "site:hanzi.crazydan.io:gen-data": "node src/site/hanzi.crazydan.io/gen-data.mjs",
    "generate:sqlite:ime": "node src/generate/sqlite/ime/index.mjs",
    "generate:sqlite:ime:debug": "node --inspect-brk src/generate/sqlite/ime/index.mjs",
    "generate:sqlite:phrase:hmm": "node src/generate/sqlite/phrase/hmm/index.mjs",
    "generate:sqlite:phrase:hmm:debug": "node --inspect-brk src/generate/sqlite/phrase/hmm/index.mjs",
    "generate:sqlite:phrase:hmm:trans": "node src/generate/sqlite/phrase/hmm/trans/index.mjs",
    "generate:sqlite:phrase:hmm:trans:debug": "node --inspect-brk src/generate/sqlite/phrase/hmm/trans/index.mjs",
    "generate:sqlite:phrase:hmm:trans_kewen": "node src/generate/sqlite/phrase/hmm/trans_kewen/index.mjs"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^3.3.0",
    "fontkit": "^2.0.2",
    "get-system-fonts": "^2.0.2",
    "grapheme-splitter": "^1.0.4",
    "jsdom": "^22.1.0"
  }
}
